# Secrets — never commit
.env
youtube_token.pickle
youtube_client_secret.json

# Large/regenerable local output — audio, video, scripts are rebuilt by the
# pipeline and too large for git; persisted in Supabase Storage instead.
output/
*.mp4
*.mp3
*.wav
# Exception: the shared ambient music bed IS a required input (not disposable
# output) — agents/music_agent.py loops/trims it on the GitHub Actions
# runner, which starts from a fresh checkout with nothing else cached.
!assets/shared_ambient.mp3

# Local image/thumbnail assets — large binaries, not meant to live in git history.
images/
thumbnails/
assets/music/
assets/ambience/

# Python
__pycache__/
*.pyc
.venv/
venv/

# OS
.DS_Store

# Local schedule/state cache
schedule.json
.vercel
kokoro-models/
